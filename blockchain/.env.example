# Cle privee du wallet MetaMask (avec ETH Sepolia gratuit)
# Export : MetaMask → Details du compte → Exporter la cle privee
PRIVATE_KEY=your_private_key_here

# RPC Sepolia - projet gratuit sur https://infura.io
# Exemple : https://sepolia.infura.io/v3/VOTRE_CLE_INFURA
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY

# Optionnel - verification Etherscan apres deploy
ETHERSCAN_API_KEY=your_etherscan_api_key
